{
  "name": "PDFMaster",
  "short_name": "PDFMaster",
  "description": "Free online PDF tools - Merge, Compress, Convert PDFs locally in your browser",
  "version": "1.0.0",
  "manifest_version": 3,
  "start_url": "/",
  "display": "standalone",
  "orientation": "portrait",
  "background_color": "#ffffff",
  "theme_color": "#10b981",
  "icons": [
    {
      "src": "assets/logo.png",
      "sizes": "800x800",
      "type": "image/png"
    },
    {
      "src": "assets/logo.png",
      "sizes": "800x800",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "scope": "/",
  "prefer_related_applications": false
}